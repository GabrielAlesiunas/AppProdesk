<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <!-- INTERNET -->
    <uses-permission android:name="android.permission.INTERNET" /> <!-- LOCALIZAÇÃO -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.ProDesk">
        <activity
            android:name=".MainActivity"
            android:exported="false" />
        <activity
            android:name=".PerfilActivity"
            android:exported="false" />
        <activity
            android:name=".ReservaActivity"
            android:exported="false" />
        <activity
            android:name=".VerificacaoActivity"
            android:exported="false" />
        <activity
            android:name=".CadastroActivity"
            android:exported="false" />
        <activity
            android:name=".LoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".DetalheActivity"
            android:exported="false" />
        <activity android:name=".HistoricoReservasActivity" />
        <activity android:name=".CartaoActivity"/>
        <activity android:name=".SenhaActivity"/>
        <activity android:name=".RecuperarSenhaActivity"/>
        <activity android:name=".CadastroEspacoActivity" />
    </application>

</manifest>