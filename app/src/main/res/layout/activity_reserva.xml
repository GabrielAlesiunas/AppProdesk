<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottom_navigation"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- CARD ESPAÇO -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="6dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/txtNome"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nome"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#000"/>

                    <TextView
                        android:id="@+id/txtPreco"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Preço"
                        android:textColor="#4A90E2"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp"/>

                    <TextView
                        android:id="@+id/txtDescricao"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Descrição"
                        android:textColor="#444"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- RESUMO -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Resumo da Reserva"
                        android:textStyle="bold"
                        android:textColor="#000"/>

                    <TextView
                        android:id="@+id/txtResumo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Preencha os dados"
                        android:textColor="#2ECC71"
                        android:textStyle="bold"
                        android:layout_marginTop="8dp"/>
                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- DATA INICIO -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Data de entrada"
                android:textColor="#000"
                android:textStyle="bold"/>

            <Button
                android:id="@+id/btnDataInicio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Selecionar data início"
                android:backgroundTint="#4A90E2"
                android:textColor="#FFFFFF"/>

            <TextView
                android:id="@+id/txtDataInicio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--/--/----"
                android:textColor="#000"/>

            <!-- DATA FIM -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Data de saída"
                android:textColor="#000"
                android:textStyle="bold"
                android:layout_marginTop="10dp"/>

            <Button
                android:id="@+id/btnDataFim"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Selecionar data fim"
                android:backgroundTint="#4A90E2"
                android:textColor="#FFFFFF"/>

            <TextView
                android:id="@+id/txtDataFim"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--/--/----"
                android:textColor="#000"/>

            <!-- HORA INICIO -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hora de entrada"
                android:textColor="#000"
                android:textStyle="bold"
                android:layout_marginTop="10dp"/>

            <Button
                android:id="@+id/btnHoraInicio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Selecionar hora início"
                android:backgroundTint="#4A90E2"
                android:textColor="#FFFFFF"/>

            <TextView
                android:id="@+id/txtHoraInicio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--:--"
                android:textColor="#000"/>

            <!-- HORA FIM -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hora de saída"
                android:textColor="#000"
                android:textStyle="bold"
                android:layout_marginTop="10dp"/>

            <Button
                android:id="@+id/btnHoraFim"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Selecionar hora fim"
                android:backgroundTint="#4A90E2"
                android:textColor="#FFFFFF"/>

            <TextView
                android:id="@+id/txtHoraFim"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--:--"
                android:textColor="#000"/>

            <!-- BOTÃO -->
            <Button
                android:id="@+id/btnConfirmar"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Confirmar Reserva"
                android:layout_marginTop="20dp"
                android:backgroundTint="#2ECC71"
                android:textColor="#FFFFFF"/>

        </LinearLayout>
    </ScrollView>

    <!-- BOTTOM NAV -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_navigation"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:menu="@menu/menu_bottom"
        app:labelVisibilityMode="labeled"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>