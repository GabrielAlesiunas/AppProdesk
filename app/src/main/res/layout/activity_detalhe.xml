<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:orientation="vertical"
        android:padding="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- IMAGEM PRINCIPAL -->
        <ImageView
            android:id="@+id/imgPrincipal"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_launcher_background"/>

        <!-- NOME -->
        <TextView
            android:id="@+id/nomeEspaco"
            android:text="Nome do espaço"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#4A90E2"
            android:layout_marginTop="10dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- AVALIAÇÃO -->
        <TextView
            android:id="@+id/avaliacao"
            android:text="⭐ 0.0 / 5"
            android:layout_marginTop="5dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- DESCRIÇÃO -->
        <TextView
            android:id="@+id/descricao"
            android:text="Descrição do espaço"
            android:layout_marginTop="5dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- PREÇO -->
        <TextView
            android:id="@+id/preco"
            android:text="R$ 0,00 / hora"
            android:textStyle="bold"
            android:textColor="#4A90E2"
            android:layout_marginTop="5dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- COMODIDADES -->
        <TextView
            android:text="Comodidades"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="15dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <LinearLayout
            android:id="@+id/comodidadesLayout"
            android:orientation="horizontal"
            android:layout_marginTop="5dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">

            <TextView
                android:text="Wi-Fi"
                android:background="#DDD"
                android:padding="6dp"
                android:layout_marginEnd="5dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:text="Café"
                android:background="#DDD"
                android:padding="6dp"
                android:layout_marginEnd="5dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:text="Ar condicionado"
                android:background="#DDD"
                android:padding="6dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

        </LinearLayout>

        <!-- DONO -->
        <TextView
            android:text="Dono"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="15dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/dono"
            android:text="admin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- OPINIÕES -->
        <TextView
            android:text="Opiniões dos usuários"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="15dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/opinioes"
            android:text="Nenhuma opinião registrada."
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- BOTÃO -->
        <Button
            android:id="@+id/btnReservar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Reservar"
            android:layout_marginTop="20dp"/>

    </LinearLayout>

</ScrollView>