<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#FFFFFF"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- NOME DO ESPAÇO -->
    <TextView
        android:id="@+id/txtNomeEspaco"
        android:text="Espaço"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#000000"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <!-- SUBTITULO -->
    <TextView
        android:text="Como foi sua experiência?"
        android:textColor="#666"
        android:layout_marginTop="4dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <!-- RATING -->
    <RatingBar
        android:id="@+id/ratingBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:numStars="5"
        android:stepSize="1"
        android:progressTint="@color/primary"
        android:progressBackgroundTint="#DADADA"
        android:secondaryProgressTint="@color/primary" />

    <!-- CAMPO DE TEXTO (Material) -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:hint="Conte como foi sua experiência..."
        app:boxBackgroundMode="outline"
        app:boxStrokeColor="@color/primary"
        app:expandedHintEnabled="false"
        app:hintAnimationEnabled="false"
        app:hintEnabled="true"
        app:hintTextColor="#000000">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/edtComentario"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:gravity="top"
            android:textColor="#000000" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- BOTÃO -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnEnviar"
        android:text="Enviar avaliação"
        android:textStyle="bold"
        android:layout_marginTop="24dp"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:backgroundTint="@color/primary"
        android:textColor="@color/textOnPrimary"
        app:cornerRadius="12dp"/>

</LinearLayout>