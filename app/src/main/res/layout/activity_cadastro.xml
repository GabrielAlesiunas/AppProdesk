<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_cadastro">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- CARD (MESMO DO LOGIN) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card"
            android:elevation="8dp"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- TÍTULO -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:gravity="center"
                android:text="Criar Conta"
                android:textColor="@color/primary"
                android:textSize="26sp"
                android:textStyle="bold" />

            <!-- NOME -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Nome completo"
                android:textColorHint="#000000"
                app:boxBackgroundMode="outline"
                app:boxStrokeColor="@color/stroke_selector"
                app:expandedHintEnabled="false"
                app:hintTextColor="@color/hint_selector">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/nome"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:backgroundTint="#FFFFFF"
                    android:textColor="#000000"
                    android:textColorHint="#000000" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- EMAIL -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Email"
                android:textColorHint="#000000"
                app:boxBackgroundMode="outline"
                app:boxStrokeColor="@color/stroke_selector"
                app:expandedHintEnabled="false"
                app:hintTextColor="@color/hint_selector">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/email"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:backgroundTint="#FFFFFF"
                    android:inputType="textEmailAddress"
                    android:textColor="#000000"
                    android:textColorHint="#000000" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- TELEFONE -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Telefone"
                android:textColorHint="#000000"
                app:boxBackgroundMode="outline"
                app:boxStrokeColor="@color/stroke_selector"
                app:expandedHintEnabled="false"
                app:hintTextColor="@color/hint_selector">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/telefone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:backgroundTint="#FFFFFF"
                    android:inputType="phone"
                    android:textColor="#000000"
                    android:textColorHint="#000000" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- SENHA -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Senha"
                android:textColorHint="#000000"
                app:boxBackgroundMode="outline"
                app:boxStrokeColor="@color/stroke_selector"
                app:endIconMode="password_toggle"
                app:expandedHintEnabled="false"
                app:hintTextColor="@color/hint_selector">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/senha"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:backgroundTint="#FFFFFF"
                    android:inputType="textPassword"
                    android:textColor="#000000"
                    android:textColorHint="#000000" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- CONFIRMAR SENHA -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Confirmar senha"
                android:textColorHint="#000000"
                app:boxBackgroundMode="outline"
                app:boxStrokeColor="@color/stroke_selector"
                app:endIconMode="password_toggle"
                app:expandedHintEnabled="false"
                app:hintTextColor="@color/hint_selector">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/confirmarSenha"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:backgroundTint="#FFFFFF"
                    android:inputType="textPassword"
                    android:textColor="#000000"
                    android:textColorHint="#000000" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- TERMOS -->
            <CheckBox
                android:id="@+id/checkTermos"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Aceito os termos de uso"
                android:textColor="@color/textPrimary" />

            <!-- BOTÃO -->
            <Button
                android:id="@+id/btnCadastrar"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="16dp"
                android:backgroundTint="@color/primary"
                android:text="Cadastrar"
                android:textColor="@color/textOnPrimary" />

            <!-- VOLTAR LOGIN -->
            <TextView
                android:id="@+id/btnVoltar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:text="Já tem conta? Entrar"
                android:textColor="@color/textPrimary"
                android:textSize="12sp"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>